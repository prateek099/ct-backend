# Copy this file to .env and fill in your values.
#
#   Mac / Linux:  cp .env.example .env
#   Windows:      Copy-Item .env.example .env

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Creator Tools API"
DEBUG=false
ENVIRONMENT=development          # development | staging | production

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres-only. Local dev runs the docker-compose `db` service. Render injects
# DATABASE_URL automatically in production — paste it as-is, the app normalises
# postgres:// → postgresql+psycopg:// (psycopg3) at startup.
DATABASE_URL=postgresql+psycopg://ct_user:ct_pass@db:5432/creator_tools

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   Mac / Linux:  openssl rand -hex 32
#   Windows:      python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── External APIs ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
YOUTUBE_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty                # pretty (coloured, local dev) | json (production)
