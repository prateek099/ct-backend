# Copy this file to .env and fill in your values.
#
#   Mac / Linux:  cp .env.example .env
#   Windows:      Copy-Item .env.example .env

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Creator Tools API"
DEBUG=false
ENVIRONMENT=development          # development | staging | production

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite — zero setup, perfect for local dev and CI
DATABASE_URL=sqlite:///./ct.db

# PostgreSQL — uncomment and fill in when switching from SQLite.
# Uses psycopg3 (NOT psycopg2). The prefix must be postgresql+psycopg://
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ct_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   Mac / Linux:  openssl rand -hex 32
#   Windows:      python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── External APIs ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
YOUTUBE_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty                # pretty (coloured, local dev) | json (production)
